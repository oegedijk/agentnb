#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys


def main() -> int:
    argv = sys.argv[1:]
    if len(argv) >= 2 and argv[0] == "-c":
        code = argv[1].strip()
        if code == "import sys":
            return 0
        if code == "import ipykernel_launcher":
            return 1
        if code == "import pip":
            return 1
    return subprocess.call([sys.executable, *argv], env=os.environ.copy())


if __name__ == "__main__":
    raise SystemExit(main())
